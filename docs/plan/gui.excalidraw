      "updated": 1779239348236,
      "link": null,
      "locked": false,
      "text": "Tapping on the calendar box\nwill bring to the \"Per day's page\"",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Tapping on the calendar box\nwill bring to the \"Per day's page\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "lF198x3j767_uK3HhxU4r",
      "type": "text",
      "x": 1187.267558345768,
      "y": 2757.507077062477,
      "width": 424.9996032714844,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBD",
      "roundness": null,
      "seed": 1084091462,
      "version": 941,
      "versionNonce": 1624264154,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779239395018,
      "link": null,
      "locked": false,
      "text": "When open the Per day's page and enters,\nif you click back on the Schedule navigation\nbutton again, it will go back to the\nprevious state in the Schedule page - \nmeaning, if you were in January 2026,\nit will go back to that calendar month\nrather than going to the default current\nmonth.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When open the Per day's page and enters,\nif you click back on the Schedule navigation\nbutton again, it will go back to the\nprevious state in the Schedule page - \nmeaning, if you were in January 2026,\nit will go back to that calendar month\nrather than going to the default current\nmonth.",
      "autoResize": true,
      "lineHeight": 1.25
    },
